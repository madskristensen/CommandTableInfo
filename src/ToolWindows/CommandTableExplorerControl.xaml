<UserControl x:Class="CommandTableInfo.ToolWindows.CommandTableExplorerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CommandTableInfo.ToolWindows"
             xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
             xmlns:catalog="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
             mc:Ignorable="d"
             local:VsTheme.UseVsTheme="true"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="CopyButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTip" Value="Copy to clipboard" />
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Name="txtFilter" Grid.Column="0" Margin="5, 5, 5, 5" Height="25" TextWrapping="Wrap" TextChanged="TextBox_TextChanged"/>
                <CheckBox Name="cbInspect" Grid.Column="1"
                          Content="Inspect mode"
                          VerticalContentAlignment="Center" VerticalAlignment="Center"
                          Margin="10 0 10 0"
                          Padding="4 -3 0 0"
                          Unchecked="CheckBox_Checked" Checked="CheckBox_Checked"/>
            </Grid>

            <ListView Name="list" Grid.Row="1" Margin="5" ItemsSource="{Binding Commands}"
                      SelectionChanged="OnSelectionChanged"
                      SelectionMode="Single"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.IsVirtualizing="True">

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Label Content="{Binding Name}" ToolTip="{Binding Name}" Height="26" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" />

        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Column="2">
            <Grid Name="details" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2">
                    <Label Content="Name.Of.Command" Name="txtName" VerticalAlignment="Bottom" FontWeight="Bold" FontSize="14" Grid.Row="0" />
                    <Button Name="btnCopyName" Style="{StaticResource CopyButtonStyle}" Click="CopyName_Click" VerticalAlignment="Bottom" Margin="0,0,0,4">
                        <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.Copy}" />
                    </Button>
                    <Label Name="btnExecute" VerticalAlignment="Bottom">
                        <Hyperlink Click="Hyperlink_Click">
                            Execute
                        </Hyperlink>
                    </Label>
                </StackPanel>

                <Grid Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Vertical" Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="10 0 0 0">
                            <Label Content="Guid" Width="110" FontWeight="Bold" />
                            <TextBox Text="n/a" Name="txtGuid" IsReadOnly="True" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Margin="0 0 4 0" />
                            <Button Name="btnCopyGuid" Style="{StaticResource CopyButtonStyle}" Click="CopyGuid_Click">
                                <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.Copy}" />
                            </Button>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="10 0 0 0">
                            <Label Content="ID" Width="110" FontWeight="Bold" />
                            <TextBox Text="n/a" Name="txtId" IsReadOnly="True" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Margin="0 0 4 0" />
                            <Button Name="btnCopyId" Style="{StaticResource CopyButtonStyle}" Click="CopyId_Click">
                                <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.Copy}" />
                            </Button>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="10 0 0 0">
                            <Label Content="Key bindings" Width="110" FontWeight="Bold"/>
                            <TextBox Name="txtBindings" Text="n/a" Background="Transparent" BorderThickness="0" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0 0 4 0" />
                            <Button Name="btnCopyBindings" Style="{StaticResource CopyButtonStyle}" Click="CopyBindings_Click">
                                <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.Copy}" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
