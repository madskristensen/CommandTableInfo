<UserControl x:Class="CommandTableInfo.ToolWindows.CommandTableExplorerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CommandTableInfo.ToolWindows"
             xmlns:platformui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
             xmlns:catalog="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
             mc:Ignorable="d"
             local:VsTheme.UseVsTheme="true"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <HierarchicalDataTemplate DataType="{x:Type local:HierarchyTreeNode}" ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap" />
        </HierarchicalDataTemplate>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="CaretBrush" Value="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ToolTip" Value="Search by name, guid, ID, or key binding" />
        </Style>

        <Style x:Key="SplitterThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowBorderBrushKey}}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource {x:Static platformui:EnvironmentColors.CommandBarHoverOverSelectedIconBrushKey}}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DetailLabelStyle" TargetType="Label">
            <Setter Property="Width" Value="110" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="DetailValueTextBoxStyle" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="24" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="5"
                        Padding="4,0"
                        BorderThickness="1"
                        CornerRadius="2"
                        BorderBrush="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowBorderBrushKey}}"
                        Background="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowBackgroundBrushKey}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <imaging:CrispImage Grid.Column="0"
                                            Width="16"
                                            Height="16"
                                            Margin="2,0,6,0"
                                            VerticalAlignment="Center"
                                            Moniker="{x:Static catalog:KnownMonikers.Search}" />

                        <TextBox Name="txtFilter"
                                 Grid.Column="1"
                                 MinHeight="24"
                                 TextChanged="TextBox_TextChanged"
                                 Style="{StaticResource SearchTextBoxStyle}" />
                    </Grid>
                </Border>

                <CheckBox Name="cbInspect" Grid.Column="1"
                          Content="Inspect mode"
                          VerticalContentAlignment="Center" VerticalAlignment="Center"
                          Margin="8,0,10,0"
                          Padding="0"
                          Unchecked="CheckBox_Checked" Checked="CheckBox_Checked"/>
            </Grid>

            <ListView Name="list" Grid.Row="1" Margin="5" ItemsSource="{Binding Commands}"
                      SelectionChanged="OnSelectionChanged"
                      SelectionMode="Single"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.IsVirtualizing="True">

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Label Content="{Binding Name}" ToolTip="{Binding Name}" Height="26" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <GridSplitter Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowBorderBrushKey}}"
                      ShowsPreview="True"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Columns">
            <GridSplitter.Template>
                <ControlTemplate TargetType="GridSplitter">
                    <Thumb Style="{StaticResource SplitterThumbStyle}" />
                </ControlTemplate>
            </GridSplitter.Template>
        </GridSplitter>

        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Name="details" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.Row="0">
                    <Label Content="Name.Of.Command"
                           Name="txtName"
                           VerticalAlignment="Bottom"
                           FontWeight="Bold"
                           FontSize="14"
                           Foreground="{DynamicResource {x:Static platformui:EnvironmentColors.ToolWindowTextBrushKey}}"
                           Grid.Row="0" />
                    <Label Name="btnExecute" VerticalAlignment="Bottom">
                        <Hyperlink Click="Hyperlink_Click">
                            Execute
                        </Hyperlink>
                    </Label>
                </StackPanel>

                <Grid Grid.Column="0" Grid.Row="1" Margin="10,0,0,0" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="Display name" Style="{StaticResource DetailLabelStyle}" />
                    <TextBox Grid.Row="0" Grid.Column="1" Name="txtDisplayName" Text="n/a" Style="{StaticResource DetailValueTextBoxStyle}" Margin="0,0,4,0" PreviewMouseRightButtonUp="DetailsTextBox_PreviewMouseRightButtonUp" />

                    <Label Grid.Row="1" Grid.Column="0" Content="Guid" Style="{StaticResource DetailLabelStyle}" />
                    <TextBox Grid.Row="1" Grid.Column="1" Name="txtGuid" Text="n/a" Style="{StaticResource DetailValueTextBoxStyle}" Margin="0,0,4,0" PreviewMouseRightButtonUp="DetailsTextBox_PreviewMouseRightButtonUp" />

                    <Label Grid.Row="2" Grid.Column="0" Content="ID" Style="{StaticResource DetailLabelStyle}" />
                    <TextBox Grid.Row="2" Grid.Column="1" Name="txtId" Text="n/a" Style="{StaticResource DetailValueTextBoxStyle}" Margin="0,0,4,0" PreviewMouseRightButtonUp="DetailsTextBox_PreviewMouseRightButtonUp" />

                    <Label Grid.Row="3" Grid.Column="0" Content="Guid/ID pair" Style="{StaticResource DetailLabelStyle}" />
                    <TextBox Grid.Row="3" Grid.Column="1" Name="txtGuidId" Text="n/a" Style="{StaticResource DetailValueTextBoxStyle}" Margin="0,0,4,0" PreviewMouseRightButtonUp="DetailsTextBox_PreviewMouseRightButtonUp" />

                    <Label Grid.Row="4" Grid.Column="0" Content="Button text" Style="{StaticResource DetailLabelStyle}" />
                    <TextBox Grid.Row="4" Grid.Column="1" Name="txtButtonText" Text="n/a" Style="{StaticResource DetailValueTextBoxStyle}" Margin="0,0,4,0" AcceptsReturn="True" VerticalAlignment="Top" PreviewMouseRightButtonUp="DetailsTextBox_PreviewMouseRightButtonUp" />

                    <Label Grid.Row="5" Grid.Column="0" Content="Key bindings" Style="{StaticResource DetailLabelStyle}" />
                    <TextBox Grid.Row="5" Grid.Column="1" Name="txtBindings" Text="n/a" Style="{StaticResource DetailValueTextBoxStyle}" Margin="0,0,4,0" AcceptsReturn="True" VerticalAlignment="Top" PreviewMouseRightButtonUp="DetailsTextBox_PreviewMouseRightButtonUp" />
                </Grid>

                <Grid Grid.Column="0" Grid.Row="2" Margin="10,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="Hierarchy" Style="{StaticResource DetailLabelStyle}" />
                    <TreeView Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Name="treeHierarchy" Margin="0,2,0,0" MinHeight="120" BorderThickness="0" Background="Transparent" PreviewMouseRightButtonDown="TreeHierarchy_PreviewMouseRightButtonDown" PreviewMouseRightButtonUp="TreeHierarchy_PreviewMouseRightButtonUp" />
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
